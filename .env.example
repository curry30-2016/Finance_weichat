# DeepSeek API Key (从 https://platform.deepseek.com/ 获取)
DEEPSEEK_API_KEY=sk-xxxxxxxx

# 企业微信机器人 Webhook URL (企业微信 -> 群设置 -> 群机器人 -> webhook 地址)
WEWORK_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxxxxx

# 每个新闻源最多采集条数
NEWS_LIMIT_PER_SOURCE=10

# 传给 LLM 的新闻总数上限
MAX_NEWS_TOTAL=30
